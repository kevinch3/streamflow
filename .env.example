# Copy this file to .env and set real values before deploying
#
# Generate a strong token:  openssl rand -base64 28
# Generate a callback secret: openssl rand -base64 24
# Generate a publish secret:  openssl rand -base64 24
# Supabase Postgres URL:      postgresql://postgres:<password>@<host>:5432/postgres?sslmode=require
#
STREAM_API_TOKEN=
MEDIAMTX_AUTH_SECRET=
PUBLISH_TOKEN_SECRET=
PORT=80
PERSISTENCE_MODE=postgres
DATABASE_URL=
DATABASE_SSL=true
# DATABASE_STATEMENT_TIMEOUT_MS=10000

# Production only (Phase 2) — used by docker-compose.prod.yml
# GITHUB_REPOSITORY=owner/repo   (lowercase, e.g. kevinch3/streamflow)
# IMAGE_TAG=latest
