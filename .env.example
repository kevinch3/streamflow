# Copy this file to .env and set real values before deploying
#
# Generate a strong token:  openssl rand -base64 28
# Generate a publish key:   openssl rand -base64 21
#
STREAM_API_TOKEN=
RTMP_PUBLISH_KEY=
PORT=80

